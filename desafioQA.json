// 1. Cria a massa de dados apenas na primeira execução do loop
if (!pm.variables.get("lista_equipamentos")) {
    let massa_dados = [
        // Cenários Positivos 
        { nome: "Monitor Samsung 24", patrimonio: "EEEP-MON-001", categoria: "Computadores", statusEsperado: 201 },
        { nome: "Mouse Logitech", patrimonio: "EEEP-AC-002", categoria: "Acessórios", statusEsperado: 201 },
        
        // Cenários Negativos / Desafio do QA
        { nome: "", patrimonio: "EEEP-AC-999", categoria: "Acessórios", statusEsperado: 400 }, // Erro: Nome vazio
        { nome: "Kit Sensor Ultrassônico", patrimonio: "EEEP-ROB-003", categoria: "", statusEsperado: 400 }, // Erro: Categoria vazia
        
        { nome: "Raspberry Pi 4", patrimonio: "EEEP-ROB-005", categoria: "Robótica", statusEsperado: 201 }
    ];
    
    // Converte o array para texto JSON para conseguir guardar na memória do Postman
    pm.variables.set("lista_equipamentos", JSON.stringify(massa_dados));
}

let equipamentos = JSON.parse(pm.variables.get("lista_equipamentos"));

let equipamentoAtual = equipamentos.shift();

pm.variables.set("lista_equipamentos", JSON.stringify(equipamentos));

pm.variables.set("nome", equipamentoAtual.nome);
pm.variables.set("patrimonio", equipamentoAtual.patrimonio);
pm.variables.set("categoria", equipamentoAtual.categoria);

// 6. Guarda o status esperado para que a aba "Tests" faça a validação correta
pm.variables.set("statusEsperado", equipamentoAtual.statusEsperado);

console.log("Preparando: " + (equipamentoAtual.nome || "[SEM NOME]") + " | Status esperado: " + equipamentoAtual.statusEsperado); //p saber oq ta sendo enviado