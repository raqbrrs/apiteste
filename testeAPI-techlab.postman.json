      "item": [
        {
          "name": "POST Emprestar Equipamento",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code é 400\", function () {\r",
                  "    // O sistema deve recusar a requisição por causa do nome curto\r",
                  "    pm.response.to.have.status(400);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Valida erro de nome curto\", function () {\r",
                  "    let responseText = pm.response.text();\r",
                  "    \r",
                  "    // Transforma em texto e verifica se a resposta acusa o erro esperado\r",
                  "    // (Pode ser uma mensagem contendo 'responsavel', 'caracteres', 'tamanho' ou 'inválido')\r",
                  "    pm.expect(responseText.toLowerCase()).to.match(/responsavel|erro|caracter|tamanho|invalido/);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"responsavel_atual\": \"Zé\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:3000/equipamentos/2/emprestar",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "equipamentos",
                "2",
                "emprestar"
              ]
            }
          },
          "response": []
        },
